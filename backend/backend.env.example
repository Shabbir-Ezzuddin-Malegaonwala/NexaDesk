# ─── Database ───────────────────────────────────────────────
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/nexadesk

# ─── BetterAuth ─────────────────────────────────────────────
# Any long random string — used to sign session tokens
# You can generate one at: https://generate-secret.vercel.app/32
BETTER_AUTH_SECRET=your-super-secret-key-here

# URL of this backend service
BETTER_AUTH_URL=http://localhost:3001

# ─── CORS ───────────────────────────────────────────────────
# URL of the frontend (for CORS whitelist)
FRONTEND_URL=http://localhost:3000

# ─── AI Service ─────────────────────────────────────────────
# URL of the FastAPI AI service
AI_SERVICE_URL=http://localhost:8000
